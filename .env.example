# Copy this file to .env and fill in your values

# PostgreSQL connection string
# Local:      postgresql://postgres:password@localhost:5432/portfolio
# Railway:    provided automatically when you add a PostgreSQL service
DATABASE_URL="postgresql://postgres:password@localhost:5432/portfolio"

# JWT secret — generate a strong random string (min 32 chars)
# Tip: run  openssl rand -base64 32  to generate one
JWT_SECRET="change-this-to-a-strong-random-secret-at-least-32-chars"

# Admin login credentials (change before deploying!)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="your-strong-password-here"

# Public site URL (used for SEO / og tags)
NEXT_PUBLIC_SITE_URL="https://your-railway-domain.up.railway.app"
